{
  "tasks": {
    "fmt": "deno fmt deno.json README.md index.html src vite.config.ts tsconfig.json tsconfig.node.json",
    "fmt:check": "deno fmt --check deno.json README.md index.html src vite.config.ts tsconfig.json tsconfig.node.json",
    "lint": "deno lint src vite.config.ts",
    "check": "deno check src/main.tsx src/tests/peer-session.test.ts src/tests/sync-service.test.ts",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "deno test --allow-all src/tests"
  },
  "compilerOptions": {
    "lib": ["deno.ns", "dom", "dom.iterable", "es2022"],
    "jsx": "react-jsx",
    "jsxImportSource": "npm:react@^18.3.0",
    "types": ["npm:@types/react@^18.3.12", "npm:@types/react-dom@^18.3.1"]
  },
  "imports": {
    "@std/expect": "jsr:@std/expect@1",
    "@std/testing": "jsr:@std/testing@1",
    "@types/react": "npm:@types/react@^18.3.12",
    "@types/react-dom": "npm:@types/react-dom@^18.3.1",
    "@vitejs/plugin-react": "npm:@vitejs/plugin-react@^4.3.0",
    "d3": "npm:d3@^7.9.0",
    "react": "npm:react@^18.3.0",
    "react/jsx-runtime": "npm:react@^18.3.0/jsx-runtime",
    "react-dom/client": "npm:react-dom@^18.3.0/client",
    "vite": "npm:vite@^6.0.0"
  }
}
