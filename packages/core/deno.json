{
  "name": "@mydenicek/core",
  "version": "0.1.0",
  "description": "CRDT for collaborative editing of tagged document trees.",
  "license": "MIT",
  "exports": {
    ".": "./mod.ts",
    "./internal": "./internal.ts"
  },
  "publish": {
    "exclude": ["tests/", "tools/"]
  },
  "tasks": {
    "fmt": "deno fmt mod.ts internal.ts core tests tools deno.json",
    "fmt:check": "deno fmt --check mod.ts internal.ts core tests tools deno.json",
    "lint": "deno lint . && deno doc --lint mod.ts",
    "check": "deno check mod.ts tests/**/*.ts",
    "test": "deno test --allow-all --no-check tests",
    "property-test": "deno test tests/core-properties.test.ts --allow-all",
    "random-fuzzer": "deno run tools/core-random-fuzzer.ts"
  },
  "imports": {
    "@std/assert": "../../tools/deno_std/assert.ts",
    "@std/data-structures/binary-heap": "../../tools/deno_std/binary-heap.ts",
    "@std/random": "jsr:@std/random",
    "fast-check": "npm:fast-check@^4.5.3"
  }
}
